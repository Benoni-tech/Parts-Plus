{
  "expo": {
    "name": "Parts Plus",
    "slug": "parts-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "partsplus",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFD700"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.company.partsplus"
    },
    "android": {
      "package": "com.company.partsplus",
      "adaptiveIcon": {
        "backgroundColor": "#FFD700",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFD700",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "firebase": {
        "apiKey": "AIzaSyCQYIJP-Q5G3aeRtMSVXpAf_8_HRSEN5Wo",
        "authDomain": "parts-plus-8dd3f.firebaseapp.com",
        "projectId": "parts-plus-8dd3f",
        "storageBucket": "parts-plus-8dd3f.firebasestorage.app",
        "messagingSenderId": "1016604643982",
        "appId": "1:1016604643982:web:0e224c63845d7645b52fdf"
      },
      "eas": {
        "projectId": "parts-plus-8dd3f"
      }
    }
  }
}
